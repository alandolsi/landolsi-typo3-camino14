#!/usr/bin/env bash
## Description: Zieht DB-Dump und fileadmin von der Production-Instanz lokal.
## Usage: ddev pull-production
## Example: ddev pull-production
## HostWorkingDir: true

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/../../.env.pullpush"

# ── Konfigurationsdatei laden ────────────────────────────────────────────────
if [[ ! -f "${ENV_FILE}" ]]; then
  echo "❌ Fehler: ${ENV_FILE} nicht gefunden."
  echo "   Bitte .ddev/.env.pullpush.example kopieren und befüllen:"
  echo "   cp .ddev/.env.pullpush.example .ddev/.env.pullpush"
  exit 1
fi

# shellcheck source=/dev/null
source "${ENV_FILE}"

# ── Pflicht-Variablen prüfen ─────────────────────────────────────────────────
REQUIRED_VARS=(PROD_HOST PROD_USER PROD_DB_NAME PROD_DB_USER PROD_DB_PASSWORD PROD_FILES_PATH)
MISSING=()
for VAR in "${REQUIRED_VARS[@]}"; do
  if [[ -z "${!VAR:-}" ]]; then
    MISSING+=("${VAR}")
  fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo "❌ Fehlende Variablen in .ddev/.env.pullpush:"
  for M in "${MISSING[@]}"; do
    echo "   - ${M}"
  done
  exit 1
fi

# ── Defaults für optionale Variablen ────────────────────────────────────────
PROD_PORT="${PROD_PORT:-22}"
PROD_DB_HOST="${PROD_DB_HOST:-127.0.0.1}"
LOCAL_FILES_PATH="${LOCAL_FILES_PATH:-public/fileadmin/}"
PROD_PHP_BIN="${PROD_PHP_BIN:-php}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
TMP_DIR="/tmp/ddev-pull-${TIMESTAMP}"

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║          ddev pull-production                    ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""
echo "  Production-Host : ${PROD_HOST}:${PROD_PORT}"
echo "  DB-Name         : ${PROD_DB_NAME}"
echo "  Files-Pfad      : ${PROD_FILES_PATH}"
echo ""

# ── Temporären Ordner anlegen ────────────────────────────────────────────────
mkdir -p "${TMP_DIR}"
trap 'rm -rf "${TMP_DIR}"' EXIT

# ── DB-Dump von Production ziehen ────────────────────────────────────────────
echo "▶ Erstelle DB-Dump auf Production..."
ssh -i ~/.ssh/id_rsa \
    -p "${PROD_PORT}" \
    -o StrictHostKeyChecking=no \
    -o BatchMode=yes \
    "${PROD_USER}@${PROD_HOST}" \
    "${PROD_PHP_BIN} -r \"\" && mysqldump \
      --host='${PROD_DB_HOST}' \
      --user='${PROD_DB_USER}' \
      --password='${PROD_DB_PASSWORD}' \
      '${PROD_DB_NAME}'" \
    > "${TMP_DIR}/production.sql"

echo "▶ Importiere DB lokal via ddev import-db..."
ddev import-db --file="${TMP_DIR}/production.sql"

# ── fileadmin von Production synchronisieren ─────────────────────────────────
echo "▶ Synchronisiere fileadmin von Production → lokal..."
rsync -az \
  -e "ssh -i ~/.ssh/id_rsa -p ${PROD_PORT} -o StrictHostKeyChecking=no -o BatchMode=yes" \
  "${PROD_USER}@${PROD_HOST}:${PROD_FILES_PATH}" \
  "${LOCAL_FILES_PATH}"

# ── Lokalen TYPO3-Cache leeren ───────────────────────────────────────────────
echo "▶ TYPO3-Cache lokal flushen..."
ddev typo3 cache:flush 2>/dev/null || true

echo ""
echo "✅ pull-production abgeschlossen (${TIMESTAMP})"
echo "   Datenbank und fileadmin entsprechen jetzt dem Production-Stand."
echo ""
