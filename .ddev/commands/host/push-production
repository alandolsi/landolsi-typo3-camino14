#!/usr/bin/env bash
## Description: Überträgt lokale DB und fileadmin auf die Production-Instanz. SEHR GEFÄHRLICH!
## Usage: ddev push-production [--i-understand]
## Example: ddev push-production --i-understand
## HostWorkingDir: true

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/../../.env.pullpush"

# ── Schutz-Flag prüfen ───────────────────────────────────────────────────────
ALLOW=false
for ARG in "$@"; do
  if [[ "${ARG}" == "--i-understand" ]]; then
    ALLOW=true
  fi
done

if [[ "${ALLOW_PROD_PUSH:-}" == "1" ]]; then
  ALLOW=true
fi

if [[ "${ALLOW}" != "true" ]]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════════════╗"
  echo "║  ⚠️  WARNUNG: ddev push-production                                  ║"
  echo "║                                                                      ║"
  echo "║  Dieser Befehl überschreibt die PRODUKTIONSDATENBANK und/oder       ║"
  echo "║  den fileadmin auf dem Production-Server!                           ║"
  echo "║                                                                      ║"
  echo "║  Es gibt KEIN automatisches Backup. Alle Produktionsdaten werden    ║"
  echo "║  mit dem lokalen Stand überschrieben.                               ║"
  echo "║                                                                      ║"
  echo "║  Um fortzufahren, führe aus:                                        ║"
  echo "║    ddev push-production --i-understand                              ║"
  echo "║  oder:                                                              ║"
  echo "║    ALLOW_PROD_PUSH=1 ddev push-production                          ║"
  echo "╚══════════════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

# ── Konfigurationsdatei laden ────────────────────────────────────────────────
if [[ ! -f "${ENV_FILE}" ]]; then
  echo "❌ Fehler: ${ENV_FILE} nicht gefunden."
  echo "   Bitte .ddev/.env.pullpush.example kopieren und befüllen:"
  echo "   cp .ddev/.env.pullpush.example .ddev/.env.pullpush"
  exit 1
fi

# shellcheck source=/dev/null
source "${ENV_FILE}"

# ── Pflicht-Variablen prüfen ─────────────────────────────────────────────────
REQUIRED_VARS=(PROD_HOST PROD_USER PROD_DB_NAME PROD_DB_USER PROD_DB_PASSWORD PROD_FILES_PATH)
MISSING=()
for VAR in "${REQUIRED_VARS[@]}"; do
  if [[ -z "${!VAR:-}" ]]; then
    MISSING+=("${VAR}")
  fi
done

if [[ ${#MISSING[@]} -gt 0 ]]; then
  echo "❌ Fehlende Variablen in .ddev/.env.pullpush:"
  for M in "${MISSING[@]}"; do
    echo "   - ${M}"
  done
  exit 1
fi

# ── Defaults ────────────────────────────────────────────────────────────────
PROD_PORT="${PROD_PORT:-22}"
PROD_DB_HOST="${PROD_DB_HOST:-127.0.0.1}"
LOCAL_FILES_PATH="${LOCAL_FILES_PATH:-public/fileadmin/}"
PROD_PHP_BIN="${PROD_PHP_BIN:-php}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
TMP_DIR="/tmp/ddev-push-${TIMESTAMP}"

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║          ddev push-production  ⚠️               ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""
echo "  Production-Host : ${PROD_HOST}:${PROD_PORT}"
echo "  DB-Name         : ${PROD_DB_NAME}"
echo "  Files-Pfad      : ${PROD_FILES_PATH}"
echo ""

mkdir -p "${TMP_DIR}"
trap 'rm -rf "${TMP_DIR}"' EXIT

# ── Lokale DB exportieren ────────────────────────────────────────────────────
echo "▶ Exportiere lokale DB..."
ddev export-db --file="${TMP_DIR}/local.sql.gz" --gzip

# ── DB auf Production importieren ────────────────────────────────────────────
echo "▶ Übertrage und importiere DB auf Production..."
# Dump hochladen
rsync -az \
  -e "ssh -i ~/.ssh/id_rsa -p ${PROD_PORT} -o StrictHostKeyChecking=no -o BatchMode=yes" \
  "${TMP_DIR}/local.sql.gz" \
  "${PROD_USER}@${PROD_HOST}:/tmp/push-db-${TIMESTAMP}.sql.gz"

# Remote importieren
ssh -i ~/.ssh/id_rsa \
    -p "${PROD_PORT}" \
    -o StrictHostKeyChecking=no \
    -o BatchMode=yes \
    "${PROD_USER}@${PROD_HOST}" \
    "gunzip -c /tmp/push-db-${TIMESTAMP}.sql.gz | \
     mysql --host='${PROD_DB_HOST}' \
           --user='${PROD_DB_USER}' \
           --password='${PROD_DB_PASSWORD}' \
           '${PROD_DB_NAME}' && \
     rm -f /tmp/push-db-${TIMESTAMP}.sql.gz && \
     echo 'DB importiert.'"

# ── fileadmin nach Production rsyncen (KEIN --delete!) ────────────────────────
echo "▶ Synchronisiere fileadmin lokal → Production (ohne --delete)..."
rsync -az \
  -e "ssh -i ~/.ssh/id_rsa -p ${PROD_PORT} -o StrictHostKeyChecking=no -o BatchMode=yes" \
  "${LOCAL_FILES_PATH}" \
  "${PROD_USER}@${PROD_HOST}:${PROD_FILES_PATH}"

# ── Remote Cache flushen ─────────────────────────────────────────────────────
echo "▶ TYPO3-Cache auf Production flushen..."
ssh -i ~/.ssh/id_rsa \
    -p "${PROD_PORT}" \
    -o StrictHostKeyChecking=no \
    -o BatchMode=yes \
    "${PROD_USER}@${PROD_HOST}" \
    "cd '${PROD_FILES_PATH%fileadmin*}' 2>/dev/null || true; \
     ${PROD_PHP_BIN} vendor/bin/typo3 cache:flush 2>/dev/null || true; \
     echo 'Cache geflusht (oder kein TYPO3-CLI gefunden).'"

echo ""
echo "✅ push-production abgeschlossen (${TIMESTAMP})"
echo "   ⚠️  Produktionsdatenbank und fileadmin wurden überschrieben!"
echo ""
